{
	"name": "@running-grass/tomato-publisher",
	"version": "0.1.2",
	"description": "番茄小说作者后台 API 客户端库（多级 Service：Client → Book → Volume → Chapter）",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		}
	},
	"files": [
		"dist",
		"README.md"
	],
	"sideEffects": false,
	"scripts": {
		"clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
		"prebuild": "pnpm clean",
		"build": "tsc -p tsconfig.build.json",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"test:integration": "vitest run --dir tests/integration",
		"prepublishOnly": "pnpm build",
		"prepare": "husky",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"lint:ci": "biome ci ."
	},
	"lint-staged": {
		"*.{js,ts,mjs,cjs,json,jsonc}": [
			"biome check --write --no-errors-on-unmatched --files-ignore-unknown=true"
		]
	},
	"publishConfig": {
		"registry": "https://npm.pkg.github.com",
		"access": "restricted"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/running-grass/tomato-publisher.git"
	},
	"homepage": "https://github.com/running-grass/tomato-publisher#readme",
	"bugs": {
		"url": "https://github.com/running-grass/tomato-publisher/issues"
	},
	"engines": {
		"node": ">=20"
	},
	"dependencies": {
		"axios": "^1.13.6"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.8",
		"@commitlint/cli": "^20.5.0",
		"@commitlint/config-conventional": "^20.5.0",
		"@types/node": "^22.10.0",
		"husky": "^9.1.7",
		"lint-staged": "^16.4.0",
		"typescript": "^5",
		"vitest": "^3.0.0"
	}
}
